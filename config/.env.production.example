# ══════════════════════════════════════════════════════════════════════════════
# SampleMind AI v6 — Production Configuration Template
# ══════════════════════════════════════════════════════════════════════════════
#
# Use this file when deploying to a production or staging environment.
# Copy it to `config/.env.production`, fill in real values, and load it
# via your deployment tool or Docker --env-file flag.
#
# Key differences from the development .env.example:
#   • DEBUG is off, LOG_LEVEL is WARNING
#   • Shorter access-token TTL (15 min vs 30 min)
#   • Stricter rate limits (30 req/min vs 60 req/min)
#   • Smaller file-upload cap (50 MB vs 100 MB)
#   • Sentry DSN for error tracking
#   • All database URLs point at production hosts with auth
#
# CRITICAL: Never commit this file with real secrets.
# ══════════════════════════════════════════════════════════════════════════════

# =============================================================================
# PRODUCTION MODE
# =============================================================================

# Force production mode — disables debug toolbar, hot-reload, and verbose logs
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=WARNING
RELOAD=false

# =============================================================================
# AI API Keys (REQUIRED for production)
# =============================================================================

# Google Gemini — fast streaming provider
GOOGLE_AI_API_KEY=your_production_google_key
# OpenAI — agent workflows and fallback
OPENAI_API_KEY=your_production_openai_key

# =============================================================================
# Production Database URLs
# =============================================================================

# MongoDB Atlas or self-hosted production instance (include authSource)
MONGODB_URL=mongodb://username:password@production-mongo:27017/samplemind?authSource=admin

# Redis Cloud or self-hosted (password-protected)
REDIS_URL=redis://:password@production-redis:6379/0

# ChromaDB production instance (typically behind internal network)
CHROMADB_URL=http://chromadb-production:8002

# =============================================================================
# Security (CRITICAL - Change these!)
# =============================================================================

# Generate a strong secret (min 32 chars):
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_SECRET_KEY_32_CHARS_MINIMUM
JWT_ALGORITHM=HS256
# Shorter token lifetime in production for tighter security
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# CORS Settings
# =============================================================================

# Only allow requests from your own domains (comma-separated)
CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# =============================================================================
# Rate Limiting (Stricter for production)
# =============================================================================

# Tighter rate limits for production to control AI API costs
MAX_REQUESTS_PER_MINUTE=30
ENABLE_COST_OPTIMIZATION=true

# =============================================================================
# File Upload Limits
# =============================================================================

# Smaller upload cap in production to prevent abuse
MAX_FILE_SIZE_MB=50
# Only widely-supported lossless + lossy formats
ALLOWED_AUDIO_FORMATS=wav,mp3,flac,aiff,m4a

# =============================================================================
# Celery Production
# =============================================================================

# Celery broker and result backend (password-protected Redis, DBs 1 and 2)
CELERY_BROKER_URL=redis://:password@production-redis:6379/1
CELERY_RESULT_BACKEND=redis://:password@production-redis:6379/2

# =============================================================================
# Monitoring & Logging
# =============================================================================

# Sentry DSN for crash/error reporting (https://sentry.io)
SENTRY_DSN=your_sentry_dsn_here
# Expose Prometheus /metrics endpoint
ENABLE_METRICS=true
# cProfile profiling (disable in production for performance)
ENABLE_PROFILING=false

# =============================================================================
# Production Optimization
# =============================================================================

# Enable LRU caching for analysis results and embeddings
CACHE_ENABLED=true
# Enable batch directory processing features
BATCH_PROCESSING=true
# Number of uvicorn worker processes
MAX_WORKERS=8
# Timeout (seconds) for individual worker requests
WORKER_TIMEOUT=300
