{
  "env": {
    "CLAUDE_CODE_EFFORT_LEVEL": "auto",
    "BASH_MAX_OUTPUT_LENGTH": "30000",
    "MAX_MCP_OUTPUT_TOKENS": "25000",
    "VIRTUAL_ENV": ".venv"
  },
  "sandbox": {
    "enabled": true,
    "filesystem": {
      "denyWrite": [
        "~/.ssh",
        "~/.gnupg",
        "~/.aws"
      ]
    }
  },
  "enableAllProjectMcpServers": true,
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(pip *)",
      "Bash(uv *)",
      "Bash(ruff *)",
      "Bash(mypy *)",
      "Bash(pytest *)",
      "Bash(make *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(next *)",
      "Bash(tsc *)",
      "Bash(prettier *)",
      "Bash(eslint *)",
      "Bash(docker compose *)",
      "Bash(docker build *)",
      "Bash(docker run *)",
      "Bash(docker ps *)",
      "Bash(docker logs *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git status *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git stash *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git fetch *)",
      "Bash(git pull *)",
      "Bash(git push)",
      "Bash(git tag *)",
      "Bash(git remote *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(find *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(tree *)",
      "Bash(touch *)",
      "Bash(echo *)",
      "Bash(which *)",
      "Bash(env *)",
      "Bash(uvicorn *)",
      "Bash(celery *)",
      "Bash(aerich *)",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Agent",
      "WebFetch",
      "WebSearch"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(docker rm *)",
      "Bash(docker rmi *)",
      "Bash(docker system prune *)",
      "Bash(kill -9 *)",
      "Bash(killall *)",
      "Bash(pkill *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "echo '🎵 SampleMind AI — Phase 17 Active' && echo \"Python: $(python3 --version 2>/dev/null || echo 'not found')\" && echo \"Node: $(node --version 2>/dev/null || echo 'not found')\" && echo \"Working dir: $(pwd)\""
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "git diff --cached --name-only --diff-filter=d | grep '\\.py$' | xargs -r ruff format 2>/dev/null; git diff --cached --name-only --diff-filter=d | grep -E '\\.(ts|tsx|js|jsx)$' | xargs -r npx prettier --write 2>/dev/null; true"
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "if echo \"$TOOL_NAME\" | grep -qE 'Write|Edit'; then echo \"$FILE_PATH\" | grep -q '\\.py$' && ruff format \"$FILE_PATH\" 2>/dev/null; true; fi"
      },
      {
        "type": "command",
        "command": "if echo \"$TOOL_INPUT\" | grep -q 'pytest'; then echo '📊 Test run complete — check summary above'; fi"
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "command": "if echo \"$TOOL_INPUT\" | grep -q 'git commit'; then ruff check src/ --fix --quiet 2>/dev/null; ruff format src/ --quiet 2>/dev/null; true; fi"
      }
    ]
  }
}
