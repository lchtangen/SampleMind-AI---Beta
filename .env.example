# SampleMind AI v3.0 — Configuration Template
# Copy this file to .env and fill in your values

# =============================================================================
# AI API Keys (Get these from provider websites)
# =============================================================================

# Anthropic (Claude 3.7 Sonnet) — PRIMARY AI provider
# https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google AI (Gemini 2.0 Flash) — FAST/STREAMING provider
# https://makersuite.google.com/app/apikey
GOOGLE_AI_API_KEY=your_google_api_key_here

# OpenAI (GPT-4o) — AGENT WORKFLOW / FALLBACK provider
# https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Suno AI — Music generation (v3.0 new)
# https://suno.ai
SUNO_API_KEY=your_suno_api_key_here

# Udio AI — Music generation alternative (v3.0 new)
# https://udio.com
UDIO_API_KEY=your_udio_api_key_here

# =============================================================================
# AI Model Configuration — v3.0 defaults
# =============================================================================

# Primary model for deep analysis (Claude 3.7 Sonnet — best accuracy)
DEFAULT_MODEL=claude-3-7-sonnet-20250219

# Fast model for streaming / high-volume tasks (Gemini 2.0 Flash)
FAST_MODEL=gemini-2.0-flash

# Generation parameters
MAX_TOKENS=8192
TEMPERATURE=0.7

# =============================================================================
# Application Settings
# =============================================================================

ENVIRONMENT=development
LOG_LEVEL=INFO
CACHE_ENABLED=true
BATCH_PROCESSING=true

# =============================================================================
# Database Configuration
# =============================================================================

# MongoDB (document database)
MONGODB_URL=mongodb://mongodb:27017/samplemind

# Redis (caching and sessions)
REDIS_URL=redis://redis:6379/0

# PostgreSQL with pgvector
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=samplemind
POSTGRES_PASSWORD=samplemind123
POSTGRES_DB=samplemind
POSTGRES_SSLMODE=disable

# Vector Database
VECTOR_DIM=1536  # Dimension of the embeddings (adjust based on your model)
SIMILARITY_THRESHOLD=0.7  # Default similarity threshold for audio searching

# ChromaDB (vector database for embeddings)
CHROMADB_URL=http://localhost:8002

# =============================================================================
# Authentication
# =============================================================================

# JWT Configuration
JWT_SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_SECRET_KEY_IN_PRODUCTION
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# DAW Integration
# =============================================================================

FL_STUDIO_INTEGRATION=true
REAL_TIME_ANALYSIS=true
STREAMING_ENABLED=true

# =============================================================================
# API Configuration
# =============================================================================

# Rate limiting
MAX_REQUESTS_PER_MINUTE=60
ENABLE_COST_OPTIMIZATION=true

# v3.0 AI routing — fallback chain:
# Primary: Anthropic (Claude 3.7 Sonnet) — deep analysis, coaching
# Fast: Google AI (Gemini 2.0 Flash)     — streaming, multimodal
# Agents: OpenAI (GPT-4o)                — tool use, pipelines
# Offline: Ollama (qwen2.5:7b-instruct)  — no-internet fallback
PRIMARY_API=anthropic
FAST_API=google_ai
AGENTS_API=openai
INTELLIGENT_ROUTING=true  # Auto-route tasks to best provider

# =============================================================================
# File Upload Settings
# =============================================================================

MAX_FILE_SIZE_MB=100
ALLOWED_AUDIO_FORMATS=wav,mp3,flac,aiff,m4a,ogg,opus

# =============================================================================
# Celery (Background Tasks)
# =============================================================================

CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# =============================================================================
# Development Settings
# =============================================================================

# Enable debug mode (development only!)
DEBUG=true
RELOAD=true

# CORS settings
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# =============================================================================
# Analytics & Monitoring (PostHog)
# =============================================================================

# PostHog - Product Analytics & Session Recording
# Sign up at https://posthog.com/signup (free tier available)

# Frontend Analytics (Next.js/React)
NEXT_PUBLIC_POSTHOG_KEY=phc_your_api_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_POSTHOG_DEBUG=false  # Set to true in development to see tracking events
NEXT_PUBLIC_POSTHOG_AUTOCAPTURE=true  # Auto-capture clicks and form interactions

# Backend Analytics (FastAPI/Python)
POSTHOG_API_KEY=phc_your_api_key_here  # Use same key as frontend
POSTHOG_HOST=https://app.posthog.com
POSTHOG_ENABLED=true

# Optional: Session recording and event settings
POSTHOG_CAPTURE_RATE=1.0  # 0.0 to 1.0 (1.0 = capture all sessions)

# =============================================================================
# Beta Testing Configuration
# =============================================================================

# Beta testing settings
BETA_MODE=true
BETA_ACCESS_KEY=your_beta_key_here
ANALYTICS_ENABLED=true
FEEDBACK_WIDGET_ENABLED=true
COMMAND_PALETTE_ENABLED=true

# GitHub Integration for feedback
GITHUB_REPO_OWNER=samplemind-ai
GITHUB_REPO_NAME=samplemind-ai
GITHUB_API_TOKEN=your_github_token_here  # For creating issues from feedback widget

# =============================================================================
# Production Settings (uncomment for production)
# =============================================================================

# ENVIRONMENT=production
# DEBUG=false
# LOG_LEVEL=WARNING
# RELOAD=false
# CORS_ORIGINS=https://yourdomain.com

# =============================================================================
# Notes
# =============================================================================

# 1. Never commit .env file to git
# 2. Keep API keys secret
# 3. Use strong JWT_SECRET_KEY in production
# 4. Update MongoDB/Redis URLs for production
# 5. Set appropriate CORS_ORIGINS for your domain
