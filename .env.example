# ══════════════════════════════════════════════════════════════════════════════
# SampleMind AI v3.0 — Environment Configuration Template
# ══════════════════════════════════════════════════════════════════════════════
#
# Copy this file to `.env` in the project root and fill in real values.
# The `.env` file is git-ignored — NEVER commit it with real secrets.
#
# Sections:
#   1. AI API Keys            — credentials for each AI provider
#   2. AI Model Configuration — default model names and generation params
#   3. Application Settings   — env, logging, feature flags
#   4. Database Configuration — MongoDB, Redis, Postgres, ChromaDB
#   5. Authentication         — JWT settings
#   6. DAW Integration        — FL Studio, real-time flags
#   7. API Configuration      — rate limits, multi-provider routing
#   8. File Upload Settings   — max size, allowed formats
#   9. Celery                 — broker and result backend URLs
#  10. Development Settings   — debug, CORS, hot-reload
#  11. Analytics & Monitoring — PostHog product analytics
#  12. Beta Testing           — feature flags, feedback widget
#  13. Production overrides   — uncomment to switch to prod mode
# ══════════════════════════════════════════════════════════════════════════════

# =============================================================================
# AI API Keys (Get these from provider websites)
# =============================================================================

# Anthropic (Claude) — PRIMARY AI provider for deep analysis
# https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Gemini — Fast streaming provider (Priority 2)
# https://makersuite.google.com/app/apikey
GOOGLE_AI_API_KEY=your_google_api_key_here

# OpenAI — Agent workflows / fallback (Priority 3)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Ollama — Local offline inference (no key needed, needs `ollama serve`)
OLLAMA_HOST=http://localhost:11434

# =============================================================================
# AI Model Configuration
# =============================================================================

# Default AI model identifier (used by litellm_router when no model is specified)
DEFAULT_MODEL=claude-3-7-sonnet-20250219
# Model used specifically for music-domain analysis prompts
MUSIC_MODEL=claude-3-7-sonnet-20250219

# Max tokens per AI completion response
MAX_TOKENS=8192
# Sampling temperature (0.0 = deterministic, 1.0 = creative)
TEMPERATURE=0.7

# =============================================================================
# Application Settings
# =============================================================================

# Application environment (development | staging | production)
ENVIRONMENT=development
# Minimum log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
# Enable in-memory result caching (LRU) for audio analysis
CACHE_ENABLED=true
# Enable batch directory processing features
BATCH_PROCESSING=true

# =============================================================================
# Database Configuration
# =============================================================================

# MongoDB (document database — sample metadata, user data, library records)
MONGODB_URL=mongodb://mongodb:27017/samplemind

# Redis (in-memory cache + Celery broker + pub/sub for agent progress)
REDIS_URL=redis://redis:6379/0

# PostgreSQL with pgvector (alternative to MongoDB for production deployments)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=samplemind
POSTGRES_PASSWORD=samplemind123
POSTGRES_DB=samplemind
POSTGRES_SSLMODE=disable

# Embedding vector dimension (must match the model: CLAP = 512, OpenAI = 1536)
VECTOR_DIM=1536  # Dimension of the embeddings (adjust based on your model)
# Minimum cosine similarity for a result to be returned in audio search
SIMILARITY_THRESHOLD=0.7  # Default similarity threshold for audio searching

# ChromaDB (vector database for CLAP audio embeddings + semantic search)
CHROMADB_URL=http://localhost:8002

# =============================================================================
# Authentication
# =============================================================================

# JWT secret — generate a strong random key for production:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_SECRET_KEY_IN_PRODUCTION
# Signing algorithm (HS256 is HMAC-SHA256; no need to change this)
JWT_ALGORITHM=HS256
# Access token lifetime (short-lived for security)
ACCESS_TOKEN_EXPIRE_MINUTES=30
# Refresh token lifetime (longer; used to obtain new access tokens)
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# DAW Integration
# =============================================================================

# Enable FL Studio integration endpoint
FL_STUDIO_INTEGRATION=true
# Enable real-time analysis streaming via WebSocket
REAL_TIME_ANALYSIS=true
# Enable audio streaming playback API
STREAMING_ENABLED=true

# =============================================================================
# API Configuration
# =============================================================================

# Rate limiting
MAX_REQUESTS_PER_MINUTE=60
ENABLE_COST_OPTIMIZATION=true

# Multi-API support — 4-Tier Architecture
# Tier 0: Ollama (Instant/Offline) - QUICK_ANALYSIS only, <100ms
# Tier 1: Claude (Primary) - All deep analysis and coaching
# Tier 2: Gemini (Fast) - Genre/rhythm/streaming
# Tier 3: OpenAI (Agents/Fallback) - Agent workflows, backup
PRIMARY_API=anthropic
FAST_API=google_ai
AGENTS_API=openai
OFFLINE_API=ollama
API_ROTATION_ENABLED=false
INTELLIGENT_ROUTING=true  # Auto-route tasks to best provider

# =============================================================================
# File Upload Settings
# =============================================================================

MAX_FILE_SIZE_MB=100
ALLOWED_AUDIO_FORMATS=wav,mp3,flac,aiff,m4a,ogg,opus

# =============================================================================
# Celery (Background Tasks)
# =============================================================================

# Celery task broker (Redis DB 1)
CELERY_BROKER_URL=redis://localhost:6379/1
# Celery result backend (Redis DB 2)
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# =============================================================================
# Development Settings
# =============================================================================

# Enable debug mode (development only!)
DEBUG=true
RELOAD=true

# CORS settings
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# =============================================================================
# Analytics & Monitoring (PostHog)
# =============================================================================

# PostHog - Product Analytics & Session Recording
# Sign up at https://posthog.com/signup (free tier available)

# Frontend Analytics (Next.js/React)
NEXT_PUBLIC_POSTHOG_KEY=phc_your_api_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_POSTHOG_DEBUG=false  # Set to true in development to see tracking events
NEXT_PUBLIC_POSTHOG_AUTOCAPTURE=true  # Auto-capture clicks and form interactions

# Backend Analytics (FastAPI/Python)
POSTHOG_API_KEY=phc_your_api_key_here  # Use same key as frontend
POSTHOG_HOST=https://app.posthog.com
POSTHOG_ENABLED=true

# Optional: Session recording and event settings
POSTHOG_CAPTURE_RATE=1.0  # 0.0 to 1.0 (1.0 = capture all sessions)

# =============================================================================
# Beta Testing Configuration
# =============================================================================

# Beta testing settings
BETA_MODE=true
BETA_ACCESS_KEY=your_beta_key_here
ANALYTICS_ENABLED=true
FEEDBACK_WIDGET_ENABLED=true
COMMAND_PALETTE_ENABLED=true

# GitHub Integration for feedback
GITHUB_REPO_OWNER=samplemind-ai
GITHUB_REPO_NAME=samplemind-ai
GITHUB_API_TOKEN=your_github_token_here  # For creating issues from feedback widget

# =============================================================================
# Production Settings (uncomment for production)
# =============================================================================

# ENVIRONMENT=production
# DEBUG=false
# LOG_LEVEL=WARNING
# RELOAD=false
# CORS_ORIGINS=https://yourdomain.com

# =============================================================================
# Notes
# =============================================================================

# 1. Never commit .env file to git
# 2. Keep API keys secret
# 3. Use strong JWT_SECRET_KEY in production
# 4. Update MongoDB/Redis URLs for production
# 5. Set appropriate CORS_ORIGINS for your domain
