{
  // ─────────────────────────────────────────────────────────────────
  // EDITOR — Core
  // ─────────────────────────────────────────────────────────────────
  "editor.fontFamily": "'JetBrainsMono Nerd Font', 'Fira Code', monospace",
  "editor.fontSize": 14,
  "editor.fontLigatures": true,
  "editor.lineHeight": 1.6,
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.detectIndentation": false,
  "editor.rulers": [88, 120],
  "editor.wordWrap": "off",
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": "active",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.smoothScrolling": true,
  "editor.inlineSuggest.enabled": true,
  "editor.stickyScroll.enabled": false,
  "editor.accessibilitySupport": "off",
  "editor.unicodeHighlight.nonBasicASCII": false,
  "editor.minimap.enabled": false,
  "editor.minimap.renderCharacters": false,
  "editor.suggest.preview": true,
  "editor.inlayHints.enabled": "on",
  "editor.linkedEditing": true,

  // ─────────────────────────────────────────────────────────────────
  // LANGUAGE OVERRIDES
  // ─────────────────────────────────────────────────────────────────

  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.formatOnSave": true,
    "editor.tabSize": 4,
    "editor.rulers": [88],
    "editor.codeActionsOnSave": {
      "source.fixAll.ruff": "explicit",
      "source.organizeImports.ruff": "explicit"
    }
  },

  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.tabSize": 2
  },

  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.tabSize": 2
  },

  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.tabSize": 2
  },

  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.tabSize": 2
  },

  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.tabSize": 2
  },

  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.tabSize": 2
  },

  "[yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.tabSize": 2
  },

  "[toml]": {
    "editor.defaultFormatter": "tamasfe.even-better-toml",
    "editor.formatOnSave": true,
    "editor.tabSize": 2
  },

  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.wordWrap": "on",
    "editor.rulers": [],
    "files.trimTrailingWhitespace": false
  },

  "[shellscript]": {
    "editor.tabSize": 2,
    "editor.formatOnSave": false
  },

  "[makefile]": {
    "editor.insertSpaces": false,
    "editor.detectIndentation": false
  },

  // ─────────────────────────────────────────────────────────────────
  // PYTHON / PYLANCE
  // ─────────────────────────────────────────────────────────────────
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "python.terminal.activateEnvironment": true,
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.autoImportCompletions": true,
  "python.analysis.autoSearchPaths": true,
  "python.analysis.useLibraryCodeForTypes": true,
  "python.analysis.diagnosticMode": "workspace",
  "python.analysis.extraPaths": ["${workspaceFolder}/src"],
  "python.testing.pytestEnabled": true,
  "python.testing.pytestArgs": ["tests", "--no-cov"],
  "python.testing.unittestEnabled": false,

  // ─────────────────────────────────────────────────────────────────
  // RUFF
  // ─────────────────────────────────────────────────────────────────
  "ruff.lint.enable": true,
  "ruff.lint.args": ["--config=${workspaceFolder}/pyproject.toml"],
  "ruff.format.args": ["--config=${workspaceFolder}/pyproject.toml"],
  "ruff.importStrategy": "fromEnvironment",

  // ─────────────────────────────────────────────────────────────────
  // TYPESCRIPT / JAVASCRIPT
  // ───────────────────────────────────────────────��─────────────────
  "typescript.preferences.importModuleSpecifier": "relative",
  "typescript.suggest.autoImports": true,
  "typescript.updateImportsOnFileMove.enabled": "always",
  "javascript.updateImportsOnFileMove.enabled": "always",
  "typescript.inlayHints.parameterNames.enabled": "literals",
  "typescript.inlayHints.variableTypes.enabled": false,

  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],
  "eslint.workingDirectories": [
    { "directory": "apps/web", "changeProcessCWD": true }
  ],

  "tailwindCSS.experimental.classRegex": [
    ["clsx\\(([^)]*)\\)", "(?:'|\"|`)([^']*)(?:'|\"|`)"]
  ],
  "tailwindCSS.includeLanguages": {
    "typescriptreact": "html",
    "javascriptreact": "html"
  },

  // ─────────────────────────────────────────────────────────────────
  // TERMINAL
  // ─────────────────────────────────────────────────────────────────
  "terminal.integrated.fontFamily": "monospace",
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.lineHeight": 1.1,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.scrollback": 50000,
  "terminal.integrated.mouseWheelScrollSensitivity": 3,
  "terminal.integrated.copyOnSelection": true,
  "terminal.integrated.defaultProfile.linux": "zsh",
  "terminal.integrated.shellIntegration.enabled": true,
  "terminal.integrated.gpuAcceleration": "on",
  "terminal.integrated.stickyScroll.enabled": false,
  "terminal.integrated.env.linux": {
    "VIRTUAL_ENV": "${workspaceFolder}/.venv"
  },

  // ─────────────────────────────────────────────────────────────────
  // FILES
  // ─────────────────────────────────────────────────────────────────
  "files.autoSave": "onFocusChange",
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.eol": "\n",
  "files.exclude": {
    "**/__pycache__": true,
    "**/.pytest_cache": true,
    "**/.mypy_cache": true,
    "**/.ruff_cache": true,
    "**/.semantic_cache": true,
    "**/.test_sessions": true,
    "**/.test_favorites": true,
    "**/node_modules": true,
    "**/.turbo": true,
    "**/.next": true
  },
  "files.watcherExclude": {
    "**/__pycache__/**": true,
    "**/.venv/**": true,
    "**/node_modules/**": true,
    "**/.next/**": true,
    "**/.turbo/**": true,
    "**/dist/**": true,
    "**/.pytest_cache/**": true,
    "**/.mypy_cache/**": true,
    "**/.ruff_cache/**": true,
    "**/*.egg-info/**": true,
    "**/poetry.lock": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/.venv": true,
    "**/.next": true,
    "**/.turbo": true,
    "**/dist": true,
    "**/poetry.lock": true,
    "**/package-lock.json": true,
    "**/.pytest_cache": true,
    "**/.mypy_cache": true,
    "**/.ruff_cache": true,
    "**/.semantic_cache": true
  },

  // ─────────────────────────────────────────────────────────────────
  // GIT
  // ─────────────────────────────────────────────────────────────────
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "git.autofetch": true,
  "git.autofetchPeriod": 180,
  "git.branchProtection": ["main"],
  "gitlens.hovers.currentLine.over": "line",
  "gitlens.codeLens.enabled": false,

  // ─────────────────────────────────────────────────────────────────
  // WORKBENCH
  // ─────────────────────────────────────────────────────────────────
  "workbench.colorTheme": "Cobalt2",
  "workbench.iconTheme": "catppuccin-mocha",
  "workbench.startupEditor": "none",
  "workbench.editor.tabSizing": "shrink",
  "workbench.editor.highlightModifiedTabs": true,
  "workbench.editor.wrapTabs": false,
  "workbench.list.smoothScrolling": true,
  "workbench.panel.defaultLocation": "bottom",

  // ─────────────────────────────────────────────────────────────────
  // GITHUB COPILOT
  // ─────────────────────────────────────────────────────────────────
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": true,
    "scminput": false
  },
  "github.copilot.chat.terminalChatLocation": "terminal",
  "github.copilot.chat.codeGeneration.useInstructionFiles": true,
  "github.copilot.chat.reviewSelection.enabled": true,

  // ─────────────────────────────────────────────────────────────────
  // EXTENSIONS — MISC
  // ─────────────────��───────────────────────────────────────────────
  "errorLens.enabled": true,
  "errorLens.excludeBySource": ["cSpell"],
  "redhat.telemetry.enabled": false,
  "chat.viewSessions.orientation": "stacked",
  "explorer.confirmDelete": false,
  "security.workspace.trust.untrustedFiles": "open",
  "docker.showStartPage": false,
  "editorconfig.generateAuto": false
}
