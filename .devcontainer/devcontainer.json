{
  "name": "SampleMind AI Dev (Python 3.12)",
  "image": "mcr.microsoft.com/devcontainers/python:3.12-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {"version": "22"},
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "postCreateCommand": "pip install -e '.[dev]' 2>/dev/null || pip install -r requirements.txt && cd apps/web && npm install --legacy-peer-deps 2>/dev/null || true",
  "postStartCommand": "git fetch --all --prune && git pull --rebase origin $(git branch --show-current) 2>/dev/null || true",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.mypy-type-checker",
        "charliermarsh.ruff",
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "ms-azuretools.vscode-docker",
        "tamasfe.even-better-toml"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "[python]": {"editor.defaultFormatter": "charliermarsh.ruff"},
        "github.copilot.chat.codeGeneration.useInstructionFiles": true,
        "chat.agent.enabled": true,
        "python.defaultInterpreterPath": "${containerWorkspaceFolder}/.venv/bin/python",
        "python.terminal.activateEnvironment": true
      }
    }
  },
  "forwardPorts": [8000, 8080, 3000, 11434],
  "remoteUser": "vscode",
  "containerEnv": {
    "VIRTUAL_ENV": "${containerWorkspaceFolder}/.venv",
    "COPILOT_CUSTOM_INSTRUCTIONS_DIRS": "${containerWorkspaceFolder}/.github/instructions"
  }
}
